# legacy-peer-deps=true について（不要になったら削除可）
#
# 理由:
#   eslint-plugin-react@7.37.5 の peerDependencies の eslint 範囲が
#   "^3 || ... || ^9.7" で ESLint 10 を含んでいない（宣言が古いだけで実際は動作する）。
#   npm 7+ は peer を厳格に解決するため、この設定が無いと
#   `npm install` / `npm ci` が ERESOLVE で失敗する。yarn 時代の緩い peer 解決と同等にするための回避設定。
#
# 削除してよい条件（いずれか）:
#   - eslint-plugin-react が peer 範囲に eslint 10 を含むバージョンへ更新された
#   - もしくは ESLint を eslint-plugin-react が対応する版へ変更した
#
# 確認方法:
#   この行をコメントアウト/削除して `rm -rf node_modules package-lock.json && npm install` を実行。
#   ERESOLVE が出なければこの設定はもう不要。
legacy-peer-deps=true
